# Auto-Sourcer & Export Bot Environment Variables
# Copy this file to .env and fill in your real values.

# --- eBay API Credentials ---
# https://developer.ebay.com でアプリを作成して取得
EBAY_APP_ID=your-ebay-app-id
EBAY_DEV_ID=your-ebay-dev-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_AUTH_TOKEN=your-ebay-user-access-token

# --- Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key

# --- Slack Webhooks ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL_ORDERS=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_URL_MESSAGES=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --- Google Integration ---
GOOGLE_CREDENTIALS_PATH=./google_credentials.json
SPREADSHEET_ID=your-spreadsheet-id
SOURCING_SHEET_NAME=自動出品

# --- Financial Configurations ---
# 現在の為替レート (1 USD = ? JPY)
USD_JPY_RATE=159.2

# 目標とする利益のしきい値 (JPY)
# 利益額がこの数値以上の商品のみをシートに記録します。
PROFIT_THRESHOLD_JPY=3000
