# VPS ヘルスチェック用（inventory_health_check.sh が読み込む）
# 使い方: cp scripts/vps.env.example scripts/vps.env
#         値を書き換え（scripts/vps.env は .gitignore 済み）

VPS_HOST=133.117.76.193
VPS_USER=root
VPS_SSH_PORT=22
# 秘密鍵パス（BatchMode 用）
VPS_SSH_KEY=${HOME}/.ssh/mercari_vps

# VPS 上のボットルート（SSH できたあと inventory_manager.py がある場所）
# 例: /root/japan-export-bot  /opt/bot  など
VPS_BOT_ROOT=/opt/mercari_monitor

# 在庫管理 cron: 既定では eBay を在庫0にしない（config の INVENTORY_APPLY_EBAY_OOS）。
# 自動OOSを使うときだけ VPS の /opt/export-bot/.env に次を書く:
# INVENTORY_APPLY_EBAY_OOS=1
